# Formatting for x4sb. Matches the existing house style: 2-space indent, attached
# braces, `Type& name` / `Type* name`, and `}  // namespace x4sb` trailers.
#
# requires clang-format 22.1.5 (pinned, reproducible cross-platform).
#   install: pip install clang-format==22.1.5   (use the wheel, not system LLVM,
#   to avoid version skew — see docs/2026-06-17-known-issues.md issue 4.2).
# Run over first-party code only (third_party/ has DisableFormat):
#   clang-format -i $(git ls-files 'libs/*.cpp' 'libs/*.hpp' 'apps/*.cpp' 'apps/*.hpp' 'tests/*.cpp' 'tests/*.hpp')
# CI uses --dry-run -Werror.
---
Language:        Cpp
BasedOnStyle:    Google
Standard:        c++17

ColumnLimit:     100
IndentWidth:     2
TabWidth:        2
UseTab:          Never

PointerAlignment: Left          # Type* p, Type& r
DerivePointerAlignment: false
QualifierAlignment: Left         # west const: `const T`, not `T const`
FixNamespaceComments: true      # }  // namespace x4sb
NamespaceIndentation: None

# House style keeps short bodies on one line (the "return-early" idiom):
#   if (cond) return false;      for (auto& x : xs) f(x);
#   Vec3 appToX4(Vec3 v) { return {v.x, v.z, v.y}; }
AllowShortFunctionsOnASingleLine: All
AllowShortIfStatementsOnASingleLine: WithoutElse
AllowShortLoopsOnASingleLine: true

IncludeBlocks: Regroup
SortIncludes: CaseSensitive
IncludeCategories:
  # Paired header for a .cpp (handled by clang-format priority 0) comes first.
  - Regex:    '^<x4sb/'         # this project's own public headers
    Priority: 2
  - Regex:    '^"'              # quoted local includes
    Priority: 3
  - Regex:    '^<.*\.(h|hpp)>'  # third-party library headers
    Priority: 4
  - Regex:    '^<'             # C++ standard library
    Priority: 5
